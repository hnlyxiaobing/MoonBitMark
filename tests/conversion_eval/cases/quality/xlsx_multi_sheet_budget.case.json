{
  "id": "xlsx_test_01",
  "format": "xlsx",
  "tier": "quality",
  "input": "tests/conversion_eval/fixtures/inputs/xlsx/test_01.xlsx",
  "description": "Workbook relationships, shared strings, and multi-sheet tables should render deterministically.",
  "must_include": ["Sheet1", "Sheet2", "Sheet3", "col-1", "header (f)"],
  "must_not_include": ["undefined", "xl/workbook.xml"],
  "min_chars": 150,
  "min_lines": 10,
  "golden_markdown": "tests/conversion_eval/fixtures/expected/markdown/xlsx_test_01.md",
  "reference_builder": "xlsx",
  "checks": {
    "anchors": true,
    "golden_markdown": true,
    "ast_compare": true,
    "table_compare": true,
    "text_order": false
  },
  "weights": {
    "anchors": 0.2,
    "noise_control": 0.1,
    "markdown_similarity": 0.3,
    "ast_similarity": 0.15,
    "table_similarity": 0.25
  }
}
