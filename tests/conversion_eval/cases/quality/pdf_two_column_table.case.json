{
  "id": "pdf_multi_page",
  "format": "pdf",
  "tier": "quality",
  "input": "tests/conversion_eval/fixtures/inputs/pdf/multi_page.pdf",
  "description": "Multi-page PDF should keep long-form prose, section breaks, and key anchors across pages.",
  "must_include": ["The Evolution of the Word Processor", "Google Docs (2006)", "Track Changes"],
  "must_not_include": ["\uFFFD", "Acrobat", "<html"],
  "min_chars": 1200,
  "min_lines": 20,
  "checks": {
    "anchors": true,
    "golden_markdown": false,
    "ast_compare": false,
    "table_compare": false,
    "text_order": true
  },
  "weights": {
    "anchors": 0.35,
    "noise_control": 0.25,
    "length": 0.2,
    "text_order": 0.2
  }
}
