{
  "id": "docx_unit_test_headers",
  "format": "docx",
  "tier": "quality",
  "input": "tests/conversion_eval/fixtures/inputs/docx/unit_test_headers.docx",
  "description": "Structured DOCX headings should survive as Markdown headings in the right order.",
  "must_include": ["Test Document", "Section 1", "Section 2.1", "Paragraph 2.1.1"],
  "must_not_include": ["Normal.dotm", "w:document", "xmlns:w"],
  "min_chars": 100,
  "min_lines": 8,
  "golden_markdown": "tests/conversion_eval/fixtures/expected/markdown/docx_unit_test_headers.md",
  "reference_builder": "docx",
  "checks": {
    "anchors": true,
    "golden_markdown": true,
    "ast_compare": true,
    "table_compare": false,
    "text_order": true
  },
  "weights": {
    "anchors": 0.2,
    "noise_control": 0.15,
    "markdown_similarity": 0.3,
    "ast_similarity": 0.25,
    "text_order": 0.1
  }
}
