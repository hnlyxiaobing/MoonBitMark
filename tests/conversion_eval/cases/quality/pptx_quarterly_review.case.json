{
  "id": "pptx_simple",
  "format": "pptx",
  "tier": "quality",
  "input": "tests/conversion_eval/fixtures/inputs/pptx/simple.pptx",
  "description": "Slide titles and bullet text should stay grouped by slide order.",
  "must_include": ["Title Slide", "With a subtitle", "Things to think about"],
  "must_not_include": ["Slide Master", "PowerPoint Presentation"],
  "min_chars": 80,
  "min_lines": 6,
  "golden_markdown": "tests/conversion_eval/fixtures/expected/markdown/pptx_simple.md",
  "reference_builder": "pptx",
  "checks": {
    "anchors": true,
    "golden_markdown": true,
    "ast_compare": true,
    "table_compare": false,
    "text_order": true
  },
  "weights": {
    "anchors": 0.25,
    "noise_control": 0.1,
    "markdown_similarity": 0.35,
    "ast_similarity": 0.15,
    "text_order": 0.15
  }
}
