{
  "id": "image_bmp_mock_ocr",
  "format": "image",
  "tier": "edge",
  "input": "tests/conversion_eval/fixtures/inputs/image/bmp_24.bmp",
  "cli_args": ["--ocr", "force", "--ocr-backend", "mock"],
  "description": "BMP image inputs should also pass through the image converter and use the deterministic mock OCR backend during eval.",
  "must_include": ["Image OCR", "MOCK OCR bmp 24"],
  "must_not_include": ["OCR requested but no available backend was found.", "Unsupported OCR backend"],
  "min_chars": 40,
  "min_lines": 4,
  "checks": {
    "anchors": true,
    "golden_markdown": false,
    "ast_compare": false,
    "table_compare": false,
    "text_order": true
  },
  "weights": {
    "anchors": 0.5,
    "noise_control": 0.2,
    "length": 0.1,
    "text_order": 0.2
  }
}
