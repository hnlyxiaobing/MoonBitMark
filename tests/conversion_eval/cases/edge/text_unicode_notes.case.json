{
  "id": "text_unicode_notes",
  "format": "text",
  "tier": "edge",
  "input": "tests/conversion_eval/fixtures/inputs/text/unicode_notes.txt",
  "description": "验证 Unicode、空行和基本文本保持。",
  "must_include": ["你好", "Résumé", "Δx"],
  "must_not_include": ["�"],
  "min_chars": 20,
  "min_lines": 3,
  "golden_markdown": "tests/conversion_eval/fixtures/expected/markdown/text_unicode_notes.md",
  "checks": {
    "anchors": true,
    "golden_markdown": true,
    "ast_compare": false,
    "table_compare": false,
    "metadata_check": false,
    "text_order": false,
    "diagnostics_check": false
  }
}
