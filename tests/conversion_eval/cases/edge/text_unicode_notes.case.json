{
  "id": "text_fake_text",
  "format": "text",
  "tier": "edge",
  "input": "tests/conversion_eval/fixtures/inputs/text/fake_text.txt",
  "description": "Plain text should preserve paragraphs and bullet-like lines without introducing markup noise.",
  "must_include": ["This is a test document", "Doylestown, PA 18901", "Hamburgers are delicious"],
  "must_not_include": ["\uFFFD", "<html"],
  "min_chars": 80,
  "min_lines": 5,
  "golden_markdown": "tests/conversion_eval/fixtures/expected/markdown/text_fake_text.md",
  "reference_builder": "text",
  "checks": {
    "anchors": true,
    "golden_markdown": true,
    "ast_compare": true,
    "table_compare": false,
    "text_order": true
  },
  "weights": {
    "anchors": 0.2,
    "noise_control": 0.1,
    "length": 0.1,
    "markdown_similarity": 0.35,
    "ast_similarity": 0.15,
    "text_order": 0.1
  }
}
