{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MoonBitMark Conversion Eval Case",
  "type": "object",
  "required": ["id", "format", "tier", "input", "checks"],
  "properties": {
    "id": {"type": "string"},
    "format": {
      "type": "string",
      "enum": ["csv", "docx", "epub", "html", "json", "pdf", "pptx", "text", "xlsx"]
    },
    "tier": {
      "type": "string",
      "enum": ["smoke", "quality", "edge", "regression", "regressions"]
    },
    "input": {"type": "string"},
    "description": {"type": "string"},
    "must_include": {"type": "array", "items": {"type": "string"}},
    "must_not_include": {"type": "array", "items": {"type": "string"}},
    "min_chars": {"type": "integer", "minimum": 0},
    "min_lines": {"type": "integer", "minimum": 0},
    "golden_markdown": {"type": "string"},
    "reference_builder": {
      "type": "string",
      "enum": ["copy", "csv", "docx", "epub", "html", "json", "pptx", "text", "xlsx"]
    },
    "reference_source": {"type": "string"},
    "checks": {
      "type": "object",
      "properties": {
        "anchors": {"type": "boolean"},
        "golden_markdown": {"type": "boolean"},
        "ast_compare": {"type": "boolean"},
        "table_compare": {"type": "boolean"},
        "text_order": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "weights": {
      "type": "object",
      "properties": {
        "anchors": {"type": "number", "minimum": 0},
        "noise_control": {"type": "number", "minimum": 0},
        "length": {"type": "number", "minimum": 0},
        "markdown_similarity": {"type": "number", "minimum": 0},
        "ast_similarity": {"type": "number", "minimum": 0},
        "table_similarity": {"type": "number", "minimum": 0},
        "text_order": {"type": "number", "minimum": 0}
      },
      "additionalProperties": false
    },
    "notes": {"type": "string"}
  },
  "additionalProperties": false
}
